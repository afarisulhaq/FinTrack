# FinTrack production env. Copy to .env.production and fill in real
# values. DO NOT commit .env.production to git.
#
# `docker compose up` reads this file via `env_file:` and injects the
# variables into the container's environment.

# ── Required ─────────────────────────────────────────────
# External PostgreSQL connection string. The Docker image does NOT
# include a Postgres server — point this at your managed DB.
DATABASE_URL=postgresql://fintrack:CHANGE_ME@db.example.com:5432/fintrack?sslmode=require

# Secret used to sign JWTs. MUST be a long random string in production.
# Generate one with:  openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Next.js / Node behavior
NODE_ENV=production

# ── Bootstrap admin (required in production, ignored in dev) ──
# The seed only creates an admin in production if BOTH of these are
# set. If they are missing the seed will warn and exit without
# creating any user — you can then either set them and re-run the
# seed, or register a user via /register and promote them to admin
# with `npx prisma studio` (User.role = "admin").
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ADMIN_NAME=Your Name

# ── Optional ─────────────────────────────────────────────
# Override the Elysia backend port inside the container.
# The frontend's rewrite points at localhost:4000 by default, so if
# you change this you also have to update `next.config.mjs`.
# PORT=4000

# Where the WhatsApp bot stores its Baileys session. Defaults to
# ./.baileys-session which is mounted as a Docker volume in
# docker-compose.yml so the pairing survives image rebuilds.
# WHATSAPP_SESSION_DIR=./.baileys-session

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_CHAT_ID=

# Public API URL. Normally leave this blank so the browser uses a
# relative URL and Next.js's rewrite proxies to the backend. Set this
# only if you want the browser to talk to the backend directly (e.g.
# you expose port 4000 publicly and skip the rewrite).
# NEXT_PUBLIC_API_URL=

# Show the "Login Admin / Demo User" quick-login buttons on /login.
# Leave unset or "false" in production so the only way in is the
# normal email/password form.
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false
