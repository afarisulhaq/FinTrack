# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# database
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
# do not commit any .env files to git, except for the .env.example file. https://create.t3.gg/en/usage/env-variables#using-environment-variables
.env
.env*.local

# vercel
.vercel

# Persistent Yahoo Finance cache written by the backend at runtime.
# The compose deploy mounts a named volume on top of this, so the
# cache survives `docker compose up --build`. The directory still
# exists in the image (for the very first boot) so ignore its
# contents.
/data/

# typescript
*.tsbuildinfo

# idea files
.idea
nul
